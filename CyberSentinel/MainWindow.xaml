<Window x:Class="CyberSentinel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cyber Sentinel - Cybersecurity Chatbot"
        Height="750" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A252F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A252F"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="Foreground" Value="#1A252F"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#E8ECF1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="35"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="6" Margin="0,0,0,8" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🛡️" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="Cyber Sentinel" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔊 Voice On" x:Name="btnVoiceToggle" Click="BtnVoiceToggle_Click" 
                            Background="#2980B9" Width="110" Height="30" FontSize="12" Margin="0,0,5,0"/>
                    <Button Content="🔊 Sound On" x:Name="btnSoundToggle" Click="BtnSoundToggle_Click" 
                            Background="#27AE60" Width="110" Height="30" FontSize="12"/>
                    <Button Content="❓ Help" Click="BtnHelp_Click" Background="#3498DB" Width="80" Height="30" FontSize="12" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" x:Name="tabControl" SelectedIndex="0" Background="#F0F4F8" BorderThickness="0" Margin="0,0,0,6">

            <!-- Tab 1: Chat -->
            <TabItem Header="💬 Chat" x:Name="tabChat">
                <Grid Background="#F0F4F8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#B0BEC5" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,0,8">
                        <ScrollViewer x:Name="chatScrollViewer" VerticalScrollBarVisibility="Auto">
                            <RichTextBox x:Name="rtbChatHistory" IsReadOnly="True" BorderThickness="0"
                                         Background="White" FontSize="14" VerticalScrollBarVisibility="Auto"/>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtUserInput" Grid.Column="0" FontSize="14" Height="36" 
                                 KeyDown="TxtUserInput_KeyDown" VerticalContentAlignment="Center"/>
                        <Button x:Name="btnSend" Grid.Column="1" Content="Send" Click="BtnSend_Click" 
                                Background="#2C3E50" Width="80" Height="36" Margin="6,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Tasks -->
            <TabItem Header="📋 Tasks" x:Name="tabTasks">
                <Grid Background="#F0F4F8" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add Task Panel -->
                    <Border Grid.Row="0" BorderBrush="#B0BEC5" BorderThickness="1" CornerRadius="6" Background="White" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Title:" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtTaskTitle" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,10,0"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Description:" Margin="0,5,10,0"/>
                            <TextBox x:Name="txtTaskDesc" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,5,10,0"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Reminder (optional):" Margin="0,5,10,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5,10,0">
                                <DatePicker x:Name="dpReminder" SelectedDate="{x:Null}" Width="150" Margin="0,0,10,0"/>
                                <CheckBox x:Name="chkReminder" Content="Set reminder" VerticalAlignment="Center" Checked="ChkReminder_Checked" Unchecked="ChkReminder_Unchecked"/>
                            </StackPanel>

                            <Button x:Name="btnAddTask" Grid.Row="3" Grid.Column="1" Content="Add Task" Click="BtnAddTask_Click" 
                                    Background="#27AE60" Width="120" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Task List -->
                    <DataGrid Grid.Row="1" x:Name="dgTasks" AutoGenerateColumns="False" 
                              CanUserAddRows="False" CanUserDeleteRows="True" 
                              SelectionMode="Single" RowHeaderWidth="0"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                            <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Completed" Binding="{Binding IsCompleted}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="✅ Mark Complete" x:Name="btnComplete" Click="BtnComplete_Click" Background="#2980B9" Width="140"/>
                        <Button Content="🗑️ Delete" x:Name="btnDelete" Click="BtnDelete_Click" Background="#C0392B" Width="100"/>
                        <Button Content="🔄 Refresh" x:Name="btnRefreshTasks" Click="BtnRefreshTasks_Click" Background="#8E44AD" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Quiz -->
            <TabItem Header="🧠 Quiz" x:Name="tabQuiz">
                <Grid Background="#F0F4F8" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quiz Status -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="txtQuizScore" FontSize="14" FontWeight="Bold" Text="Score: 0" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtQuizProgress" FontSize="14" Text="Question 0/0" Margin="0,0,20,0"/>
                        <Button x:Name="btnStartQuiz" Content="▶ Start New Quiz" Click="BtnStartQuiz_Click" Background="#27AE60" Width="140"/>
                    </StackPanel>

                    <!-- Question Panel -->
                    <Border Grid.Row="1" BorderBrush="#B0BEC5" BorderThickness="1" CornerRadius="6" Background="White" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="txtQuestion" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10" MinHeight="50"/>
                            <ItemsControl x:Name="icOptions" Margin="10,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="QuizOptions" Content="{Binding}" Margin="0,5" FontSize="14" 
                                                     Checked="Option_Checked"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Feedback -->
                    <TextBlock Grid.Row="2" x:Name="txtQuizFeedback" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10" MinHeight="30"/>

                    <!-- Submit Button -->
                    <Button Grid.Row="3" x:Name="btnSubmitAnswer" Content="✅ Submit Answer" Click="BtnSubmitAnswer_Click" 
                            Background="#2C3E50" Width="140" Height="35" HorizontalAlignment="Center" IsEnabled="False"/>

                    <!-- Empty space -->
                    <Grid Grid.Row="4" Height="10"/>
                </Grid>
            </TabItem>

            <!-- Tab 4: Activity Log -->
            <TabItem Header="📜 Activity Log" x:Name="tabLog">
                <Grid Background="#F0F4F8" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄 Refresh Log" x:Name="btnRefreshLog" Click="BtnRefreshLog_Click" Background="#3498DB"/>
                        <Button Content="📋 Show All" x:Name="btnShowAllLog" Click="BtnShowAllLog_Click" Background="#8E44AD" Margin="10,0,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" x:Name="lbActivityLog" FontSize="14" BorderBrush="#B0BEC5" BorderThickness="1" 
                             Background="White" Margin="0,0,0,0" VerticalAlignment="Stretch"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer status bar -->
        <StatusBar Grid.Row="2" Background="#E8ECF1" Height="28" Margin="0,6,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Ready" Foreground="#2C3E50"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>